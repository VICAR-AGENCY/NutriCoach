# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://nutricoach:nutricoach@localhost:5432/nutricoach_dev
REDIS_URL=redis://localhost:6379

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-32-char-random-string!!
JWT_EXPIRY=7d
OTP_EXPIRY_MINUTES=10

# ── WhatsApp Business API ─────────────────────────────────────────────────────
# Meta developer console: https://developers.facebook.com/apps/
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_APP_SECRET=your_app_secret

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Firebase (FCM push notifications) ────────────────────────────────────────
FIREBASE_PROJECT_ID=nutricoach-prod
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@nutricoach-prod.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_key_here\n-----END PRIVATE KEY-----\n"

# ── Mixpanel ──────────────────────────────────────────────────────────────────
MIXPANEL_TOKEN=your_project_token
MIXPANEL_SECRET=your_api_secret

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
